---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const presentations = [
  { tag: 'algoritmos', title: 'Introducción a los Algoritmos', desc: 'Qué es un algoritmo, cómo pensarlo y cómo representarlo.' },
  { tag: 'algoritmos', title: 'Variables y Constantes', desc: 'Tipos de datos, declaración y uso de variables.' },
  { tag: 'algoritmos', title: 'Estructuras de Control', desc: 'Condicionales, bucles y lógica de flujo de programa.' },
  { tag: 'algoritmos', title: 'Funciones y Procedimientos', desc: 'Modularización del código y paso de parámetros.' },
  { tag: 'java', title: 'Introducción a Java', desc: 'Historia, instalación del JDK y primer programa en Java.' },
  { tag: 'java', title: 'Clases y Objetos', desc: 'Programación orientada a objetos: encapsulamiento y herencia.' },
  { tag: 'java', title: 'Colecciones en Java', desc: 'ArrayList, HashMap y cómo trabajar con estructuras dinámicas.' },
  { tag: 'javascript', title: 'Introducción a JavaScript', desc: 'El lenguaje de la web: historia, uso y primeras líneas de código.' },
  { tag: 'javascript', title: 'DOM y Eventos', desc: 'Manipulación del árbol DOM y manejo de eventos del navegador.' },
  { tag: 'javascript', title: 'Async / Await', desc: 'Programación asíncrona, promesas y fetch a APIs.' },
  { tag: 'c', title: 'Introducción a C', desc: 'Compilación, tipos primitivos y estructura de un programa en C.', href: '/cursos/c/1-introduccion-y-estructura' },
  { tag: 'c', title: 'Variables, Constantes y E/S', desc: 'Tipos de datos, declaración, scanf y printf.', href: '/cursos/c/3-variables-y-constantes' },
  { tag: 'c', title: 'Control de Flujo', desc: 'Decisiones e iteración: if, switch, while, for.', href: '/cursos/c/6-sentencias-de-decision' },
  { tag: 'c', title: 'Funciones y Recursividad', desc: 'Modularización, paso de parámetros y recursividad.', href: '/cursos/c/11-funciones-y-recursividad' },
  { tag: 'c', title: 'Punteros y Memoria Dinámica', desc: 'Gestión manual de memoria con malloc y free.', href: '/cursos/c/14-listas-pilas-y-colas' },
  { tag: 'c', title: 'Estructuras y Archivos', desc: 'Structs, typedef y lectura/escritura de archivos.', href: '/cursos/c/12-estructuras' },
];
---
<Layout title="Presentaciones — CodeNinja">
  <Header />
  <main class="flex-1">
    <div class="mx-auto max-w-7xl px-4 lg:px-20 py-12">
      <!-- Terminal header -->
      <div class="mb-8">
        <div class="inline-flex items-center gap-2 font-mono text-sm text-slate-400 dark:text-slate-500">
          <span class="text-primary">~/</span>presentaciones
          <span class="terminal-cursor"></span>
        </div>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-100 md:text-5xl">
          <span class="text-primary">Slides</span> de cada clase
        </h1>
        <p class="mt-3 text-slate-500 dark:text-slate-400">
          Material visual de apoyo para cada tema del curso.
        </p>
      </div>

      <div class="flex flex-col gap-8 lg:flex-row">
        <!-- Sidebar filters -->
        <aside class="w-full lg:w-52 shrink-0">
          <div class="rounded-xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 p-4">
            <p class="mb-3 font-mono text-xs text-slate-400">filtrar por tema</p>
            <div class="flex flex-row flex-wrap gap-2 lg:flex-col">
              <button
                class="filter-btn active-filter text-left rounded-lg px-3 py-2 text-sm font-mono transition-all bg-primary/10 text-primary border border-primary/20"
                data-filter="all"
              >
                ~/todos
              </button>
              <button class="filter-btn text-left rounded-lg px-3 py-2 text-sm font-mono transition-all text-slate-400 hover:text-primary hover:bg-primary/5" data-filter="algoritmos">
                ~/algoritmos
              </button>
              <button class="filter-btn text-left rounded-lg px-3 py-2 text-sm font-mono transition-all text-slate-400 hover:text-primary hover:bg-primary/5" data-filter="java">
                ~/java
              </button>
              <button class="filter-btn text-left rounded-lg px-3 py-2 text-sm font-mono transition-all text-slate-400 hover:text-primary hover:bg-primary/5" data-filter="javascript">
                ~/javascript
              </button>
              <button class="filter-btn text-left rounded-lg px-3 py-2 text-sm font-mono transition-all text-slate-400 hover:text-primary hover:bg-primary/5" data-filter="c">
                ~/c
              </button>
            </div>
          </div>
        </aside>

        <!-- Cards grid -->
        <div class="flex-1 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3" id="cards-grid">
          {presentations.map(p => (
            <div class="pres-card glow-card rounded-xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 p-5 transition-all duration-300" data-tag={p.tag}>
              <!-- macOS traffic lights -->
              <div class="mb-4 flex items-center gap-1.5">
                <span class="h-3 w-3 rounded-full bg-red-400"></span>
                <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
                <span class="h-3 w-3 rounded-full bg-green-400"></span>
                <span class="ml-2 font-mono text-xs text-slate-400">{p.tag}.slides</span>
              </div>

              <h3 class="mb-2 font-bold text-slate-900 dark:text-slate-100">{p.title}</h3>
              <p class="mb-4 text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{p.desc}</p>

              <a
                href={p.href ?? '#'}
                class={`inline-flex items-center gap-1 font-mono text-xs transition-colors ${p.href ? 'text-primary hover:underline' : 'text-slate-500 cursor-not-allowed'}`}
              >
                {p.href ? '[ EXECUTE ]' : '[ PRÓXIMAMENTE ]'}
                {p.href && (
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                )}
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .terminal-cursor {
    display: inline-block;
    width: 8px;
    height: 1em;
    background-color: #a3e635;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .glow-card {
    box-shadow: 0 0 20px rgba(163, 230, 53, 0.05), inset 0 0 10px rgba(163, 230, 53, 0.03);
  }
  .glow-card:hover {
    box-shadow: 0 0 30px rgba(163, 230, 53, 0.15), inset 0 0 15px rgba(163, 230, 53, 0.05);
    transform: translateY(-2px);
    border-color: rgba(163, 230, 53, 0.3);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.pres-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter as string;

      // Update button styles
      buttons.forEach(b => {
        b.classList.remove('active-filter', 'bg-primary/10', 'text-primary', 'border', 'border-primary/20');
        b.classList.add('text-slate-400');
      });
      btn.classList.add('active-filter', 'bg-primary/10', 'text-primary', 'border', 'border-primary/20');
      btn.classList.remove('text-slate-400');

      // Filter cards
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.tag === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
