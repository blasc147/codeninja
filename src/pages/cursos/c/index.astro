---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { COURSE, LESSONS } from '../../../data/cursos/c';
---
<Layout title={`${COURSE.title} — CodeNinja`}>
  <Header />
  <main class="flex-1">
    <!-- Hero del curso -->
    <section class="border-b border-slate-200 dark:border-slate-700/50 py-12 px-4 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <a href="/cursos" class="mb-6 inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-primary transition-colors font-mono">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Volver a cursos
        </a>

        <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
          <div>
            <div class="mb-3 flex items-center gap-3">
              <span class="rounded-full border border-primary/20 bg-primary/10 px-3 py-0.5 text-xs font-mono text-primary">
                {COURSE.badge}
              </span>
              <span class="font-mono text-xs text-slate-400">{LESSONS.length} lecciones</span>
            </div>
            <h1 class="text-4xl font-bold text-slate-900 dark:text-slate-100 md:text-5xl">
              Programación en <span class="text-primary">C</span>
            </h1>
            <p class="mt-3 max-w-xl text-slate-500 dark:text-slate-400">{COURSE.desc}</p>
          </div>

          <!-- Progress bar (cosmética) -->
          <div class="shrink-0 rounded-2xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 p-6 text-center w-48">
            <div class="text-4xl font-bold text-primary">{LESSONS.length}</div>
            <div class="mt-1 text-sm text-slate-400">lecciones</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Lista de lecciones -->
    <section class="py-12 px-4 lg:px-20">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-3">
          {LESSONS.map((lesson) => (
            <a
              href={`/cursos/c/${lesson.slug}`}
              class="group flex items-center gap-5 rounded-xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-800/50 px-6 py-4 transition-all duration-200 hover:border-primary/40 hover:shadow-[0_0_20px_-5px_rgba(163,230,53,0.2)] hover:-translate-y-0.5"
            >
              <!-- Número -->
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 font-mono text-sm font-bold text-slate-400 group-hover:border-primary/40 group-hover:text-primary transition-colors">
                {String(lesson.num).padStart(2, '0')}
              </span>

              <!-- Texto -->
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-slate-900 dark:text-slate-100 group-hover:text-primary transition-colors">
                  {lesson.title}
                </h3>
                <p class="mt-0.5 text-sm text-slate-400 truncate">{lesson.desc}</p>
              </div>

              <!-- Arrow -->
              <svg class="w-5 h-5 shrink-0 text-slate-300 dark:text-slate-600 group-hover:text-primary transition-all group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
