---
---
<section class="relative px-4 py-16 lg:px-20 lg:py-32">
  <div class="mx-auto max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
    <div class="flex flex-col gap-8">
      <div class="inline-flex w-fit items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-primary border border-primary/20">
        🥷 UTN · Programación
      </div>
      <h1 class="text-slate-900 dark:text-white text-5xl font-black leading-tight tracking-tight lg:text-7xl">
        Programá
        <span class="text-primary">like a ninja</span>
      </h1>
      <p class="text-slate-600 dark:text-slate-400 text-lg lg:text-xl max-w-xl">
        Código real, proyectos reales y contenido directo al punto para que aprendas a programar de verdad.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/cursos" class="flex h-14 items-center justify-center rounded-xl bg-primary px-8 text-lg font-bold text-background-dark hover:scale-105 transition-transform">
          Ver Cursos
        </a>
        <a href="/playground" class="flex h-14 items-center justify-center rounded-xl border border-primary/30 bg-primary/5 px-8 text-lg font-bold text-primary hover:bg-primary/10 transition-colors">
          Playground 🚧
        </a>
      </div>
    </div>

    <!-- Terminal animada -->
    <div class="relative hidden lg:block">
      <div class="absolute -inset-6 bg-primary/10 blur-3xl rounded-full"></div>
      <div class="relative rounded-2xl border border-primary/20 bg-[#0d1117] shadow-2xl overflow-hidden font-mono text-sm">

        <!-- Barra de título -->
        <div class="flex items-center gap-2 border-b border-white/5 bg-[#161b22] px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-red-400/80"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-400/80"></span>
          <span class="h-3 w-3 rounded-full bg-green-400/80"></span>
          <span class="ml-3 text-xs text-slate-500">~/codeninja/main.c</span>
        </div>

        <!-- Código -->
        <div class="p-6 leading-7 text-sm">
          <div class="line line-1"><span class="text-slate-500">#include</span> <span class="text-yellow-300">&lt;ninja.h&gt;</span></div>
          <div class="line line-2"><span class="text-slate-500">#include</span> <span class="text-yellow-300">&lt;cafe.h&gt;</span>  <span class="text-slate-600">// obligatorio</span></div>
          <div class="line line-3">&nbsp;</div>
          <div class="line line-4"><span class="text-primary/70">typedef</span> <span class="text-accent-blue">struct</span> <span class="text-yellow-200">Ninja</span> <span class="text-white">{</span></div>
          <div class="line line-5">&nbsp;&nbsp;<span class="text-accent-blue">char</span> <span class="text-white">nombre</span><span class="text-slate-400">[50]</span><span class="text-white">;</span></div>
          <div class="line line-6">&nbsp;&nbsp;<span class="text-accent-blue">int</span>  <span class="text-white">bugs_corregidos</span><span class="text-white">;</span></div>
          <div class="line line-7">&nbsp;&nbsp;<span class="text-accent-blue">int</span>  <span class="text-white">cafes_tomados</span><span class="text-white">;</span>  <span class="text-slate-600">// siempre &gt; 0</span></div>
          <div class="line line-8"><span class="text-white">}</span> <span class="text-yellow-200">Ninja</span><span class="text-white">;</span></div>
          <div class="line line-9">&nbsp;</div>
          <div class="line line-10"><span class="text-accent-blue">int</span> <span class="text-primary">main</span><span class="text-white">() {</span></div>
          <div class="line line-11">&nbsp;&nbsp;<span class="text-yellow-200">Ninja</span> <span class="text-white">yo</span> <span class="text-slate-400">=</span> <span class="text-white">{</span><span class="text-yellow-300">"vos"</span><span class="text-white">,</span> <span class="text-primary">0</span><span class="text-white">,</span> <span class="text-primary">1</span><span class="text-white">};</span></div>
          <div class="line line-12">&nbsp;</div>
          <div class="line line-13">&nbsp;&nbsp;<span class="text-slate-600">// TODO: aprender a programar</span></div>
          <div class="line line-14">&nbsp;&nbsp;<span class="text-primary/70">while</span> <span class="text-white">(yo.bugs_corregidos</span> <span class="text-slate-400">&lt;</span> <span class="text-primary">9999</span><span class="text-white">) {</span></div>
          <div class="line line-15">&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-white">estudiar();</span>  <span class="text-slate-600">// ← estás acá</span></div>
          <div class="line line-16">&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-white">yo.bugs_corregidos</span><span class="text-slate-400">++;</span></div>
          <div class="line line-17">&nbsp;&nbsp;<span class="text-white">}</span></div>
          <div class="line line-18">&nbsp;&nbsp;<span class="text-primary/70">return</span> <span class="text-yellow-300">NINJA_MODE</span><span class="text-white">;</span></div>
          <div class="line line-19"><span class="text-white">}</span></div>
          <div class="line line-20">&nbsp;</div>
          <!-- Output del compilador -->
          <div class="line line-21 border-t border-white/5 pt-3 mt-1">
            <span class="text-slate-500">$</span> <span class="text-slate-300">gcc main.c -o ninja</span>
          </div>
          <div class="line line-22">
            <span class="text-primary">✓</span> <span class="text-slate-400">Compilado exitosamente.</span>
          </div>
          <div class="line line-23 flex items-center gap-1">
            <span class="text-slate-500">$</span> <span class="text-slate-300">./ninja</span><span class="cursor-blink ml-0.5"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Cada línea entra con fade + slide desde abajo */
  .line {
    opacity: 0;
    transform: translateY(4px);
    animation: fadein 0.25s ease forwards;
  }

  @keyframes fadein {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Delays escalonados */
  .line-1  { animation-delay: 0.1s; }
  .line-2  { animation-delay: 0.2s; }
  .line-3  { animation-delay: 0.3s; }
  .line-4  { animation-delay: 0.45s; }
  .line-5  { animation-delay: 0.55s; }
  .line-6  { animation-delay: 0.65s; }
  .line-7  { animation-delay: 0.75s; }
  .line-8  { animation-delay: 0.85s; }
  .line-9  { animation-delay: 0.9s; }
  .line-10 { animation-delay: 1.0s; }
  .line-11 { animation-delay: 1.1s; }
  .line-12 { animation-delay: 1.15s; }
  .line-13 { animation-delay: 1.25s; }
  .line-14 { animation-delay: 1.4s; }
  .line-15 { animation-delay: 1.55s; }
  .line-16 { animation-delay: 1.65s; }
  .line-17 { animation-delay: 1.75s; }
  .line-18 { animation-delay: 1.9s; }
  .line-19 { animation-delay: 2.0s; }
  .line-20 { animation-delay: 2.05s; }
  .line-21 { animation-delay: 2.3s; }
  .line-22 { animation-delay: 2.6s; }
  .line-23 { animation-delay: 2.9s; }

  /* Cursor parpadeante */
  .cursor-blink {
    display: inline-block;
    width: 8px;
    height: 1em;
    background: #a3e635;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
    animation-delay: 3s;
    opacity: 0;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
